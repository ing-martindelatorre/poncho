generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  PAUSED
  FINISHED
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum MoneyKind {
  CASH
  INVOICED
}

enum PurchaseStatus {
  ORDERED
  PARTIAL
  DELIVERED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CHECK
  CARD
  OTHER
}

enum PhotoLinkType {
  PROJECT
  WEEKLY_PERIOD
  WORK_ITEM
  MATERIAL_PURCHASE
  LABOR_PAYMENT
  PAYMENT
  GENERAL
}

enum UserRole {
  ADMIN
  ARCHITECT
  CAPTURE
  READ_ONLY
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(CAPTURE)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@index([role])
  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  address     String?
  clientName  String?       @map("client_name")
  builtAreaM2 Decimal?      @map("built_area_m2") @db.Decimal(12, 2)
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?     @map("start_date") @db.Date
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  periods           WeeklyPeriod[]
  materialPurchases MaterialPurchase[]
  photos            Photo[]

  @@index([status])
  @@map("projects")
}

model WeeklyPeriod {
  id         String       @id @default(cuid())
  projectId  String       @map("project_id")
  weekNumber Int          @map("week_number")
  label      String
  startDate  DateTime     @map("start_date") @db.Date
  endDate    DateTime     @map("end_date") @db.Date
  status     PeriodStatus @default(OPEN)
  notes      String?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workItems         WorkItem[]
  laborPayments     LaborPayment[]
  materialPurchases MaterialPurchase[]
  materialDeliveries MaterialDelivery[]
  payments          Payment[]
  photos            Photo[]

  @@unique([projectId, weekNumber, startDate])
  @@index([projectId, status])
  @@map("weekly_periods")
}

model Contractor {
  id        String   @id @default(cuid())
  name      String
  trade     String?
  phone     String?
  email     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workItems     WorkItem[]
  laborPayments LaborPayment[]

  @@index([active])
  @@map("contractors")
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  taxId     String?  @map("tax_id")
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  materialPurchases MaterialPurchase[]

  @@index([active])
  @@map("suppliers")
}

model WorkItem {
  id             String    @id @default(cuid())
  weeklyPeriodId String    @map("weekly_period_id")
  contractorId   String?   @map("contractor_id")
  category       String
  description    String
  unit           String
  length         Decimal?  @db.Decimal(12, 3)
  width          Decimal?  @db.Decimal(12, 3)
  height         Decimal?  @db.Decimal(12, 3)
  pieces         Decimal?  @db.Decimal(12, 3)
  volume         Decimal   @default(0) @db.Decimal(14, 3)
  unitPrice      Decimal   @default(0) @map("unit_price") @db.Decimal(14, 2)
  total          Decimal   @default(0) @db.Decimal(14, 2)
  moneyKind      MoneyKind @default(CASH) @map("money_kind")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  weeklyPeriod WeeklyPeriod @relation(fields: [weeklyPeriodId], references: [id], onDelete: Cascade)
  contractor   Contractor?  @relation(fields: [contractorId], references: [id], onDelete: SetNull)

  @@index([weeklyPeriodId])
  @@index([contractorId])
  @@map("work_items")
}

model LaborPayment {
  id             String    @id @default(cuid())
  weeklyPeriodId String    @map("weekly_period_id")
  contractorId   String?   @map("contractor_id")
  workerName     String    @map("worker_name")
  role           String?
  days           Decimal?  @db.Decimal(10, 2)
  hours          Decimal?  @db.Decimal(10, 2)
  rate           Decimal   @default(0) @db.Decimal(14, 2)
  total          Decimal   @default(0) @db.Decimal(14, 2)
  moneyKind      MoneyKind @default(CASH) @map("money_kind")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  weeklyPeriod WeeklyPeriod @relation(fields: [weeklyPeriodId], references: [id], onDelete: Cascade)
  contractor   Contractor?  @relation(fields: [contractorId], references: [id], onDelete: SetNull)

  @@index([weeklyPeriodId])
  @@index([contractorId])
  @@map("labor_payments")
}

model MaterialPurchase {
  id             String         @id @default(cuid())
  projectId      String         @map("project_id")
  weeklyPeriodId String?        @map("weekly_period_id")
  supplierId     String?        @map("supplier_id")
  description    String
  invoiceNumber  String?        @map("invoice_number")
  quantity       Decimal?       @db.Decimal(14, 3)
  unit           String?
  unitPrice      Decimal?       @map("unit_price") @db.Decimal(14, 2)
  total          Decimal        @default(0) @db.Decimal(14, 2)
  paidAmount     Decimal        @default(0) @map("paid_amount") @db.Decimal(14, 2)
  moneyKind      MoneyKind      @default(CASH) @map("money_kind")
  status         PurchaseStatus @default(ORDERED)
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  weeklyPeriod WeeklyPeriod? @relation(fields: [weeklyPeriodId], references: [id], onDelete: SetNull)
  supplier     Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  deliveries   MaterialDelivery[]

  @@index([projectId])
  @@index([weeklyPeriodId])
  @@index([supplierId])
  @@map("material_purchases")
}

model MaterialDelivery {
  id                 String   @id @default(cuid())
  materialPurchaseId String   @map("material_purchase_id")
  weeklyPeriodId     String?  @map("weekly_period_id")
  deliveryDate       DateTime @map("delivery_date") @db.Date
  quantity           Decimal? @db.Decimal(14, 3)
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  materialPurchase MaterialPurchase @relation(fields: [materialPurchaseId], references: [id], onDelete: Cascade)
  weeklyPeriod     WeeklyPeriod?    @relation(fields: [weeklyPeriodId], references: [id], onDelete: SetNull)

  @@index([materialPurchaseId])
  @@index([weeklyPeriodId])
  @@map("material_deliveries")
}

model Payment {
  id             String        @id @default(cuid())
  weeklyPeriodId String?       @map("weekly_period_id")
  targetType     String        @map("target_type")
  targetId       String?       @map("target_id")
  description    String
  amount         Decimal       @db.Decimal(14, 2)
  method         PaymentMethod @default(TRANSFER)
  moneyKind      MoneyKind     @default(CASH) @map("money_kind")
  paidAt         DateTime      @default(now()) @map("paid_at")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  weeklyPeriod WeeklyPeriod? @relation(fields: [weeklyPeriodId], references: [id], onDelete: SetNull)

  @@index([weeklyPeriodId])
  @@index([targetType, targetId])
  @@map("payments")
}

model Photo {
  id             String        @id @default(cuid())
  projectId      String?       @map("project_id")
  weeklyPeriodId String?       @map("weekly_period_id")
  linkType       PhotoLinkType @default(GENERAL) @map("link_type")
  linkId         String?       @map("link_id")
  fileName       String        @map("file_name")
  storagePath    String        @map("storage_path")
  mimeType       String        @map("mime_type")
  sizeBytes      Int?          @map("size_bytes")
  caption        String?
  takenAt        DateTime?     @map("taken_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  weeklyPeriod WeeklyPeriod? @relation(fields: [weeklyPeriodId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([weeklyPeriodId])
  @@index([linkType, linkId])
  @@map("photos")
}
